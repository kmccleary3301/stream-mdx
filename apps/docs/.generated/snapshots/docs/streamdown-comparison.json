    {
      "id": "55f7db7a",
      "type": "list",
      "isFinalized": true,
      "payload": {
        "raw": "- **Choose Streamdown** if your priority is a minimal migration from `react-markdown` and you want streaming-tolerant formatting behavior without introducing a worker runtime.\n- **Choose StreamMDX** if your priority is worker isolation, explicit incremental patching, richer plugin/runtime control, or better guardrails for long-running / high-frequency streams.",
        "range": {
          "from": 901,
          "to": 1263
        },
        "meta": {
          "ordered": false,
          "items": [
            [
              {
