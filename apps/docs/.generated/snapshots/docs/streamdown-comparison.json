                    "kind": "text",
                    "text": "Choose Streamdown"
                  }
                ]
              },
              {
                "kind": "text",
                "text": " if your priority is a minimal migration from "
              },
              {
                "kind": "code",
                "text": "react-markdown"
              },
              {
                "kind": "text",
                "text": " and you want streaming-tolerant formatting behavior without introducing a worker runtime."
              }
            ],
            [
              {
                "kind": "strong",
                "children": [
                  {
                    "kind": "text",
                    "text": "Choose StreamMDX"
                  }
                ]
              },
              {
                "kind": "text",
                "text": " if your priority is worker isolation, explicit incremental patching, richer plugin/runtime control, or better guardrails for long-running / high-frequency streams."
