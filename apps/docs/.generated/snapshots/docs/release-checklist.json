    {
      "id": "7c11d4c2",
      "type": "list",
      "isFinalized": true,
      "payload": {
        "raw": "1. Install clean dependencies.\n\n   ```bash\n   npm ci\n   ```\n\n2. Build workspaces.\n\n   ```bash\n   npm run build\n   ```\n\n3. Build the exported docs site.\n\n   ```bash\n   npm run docs:build\n   ```\n\n4. Check documentation links and anchors.\n\n   ```bash\n   DOCS_CHECK_ANCHORS=1 npm run docs:check-links\n   ```",
        "range": {
          "from": 204,
          "to": 507
        },
        "meta": {
          "ordered": true,
          "items": [
            [
              {
                "kind": "text",
                "text": "Install clean dependencies.\n\n```bash\nnpm ci\n```\n"
              }
            ],
            [
              {
                "kind": "text",
                "text": "Build workspaces.\n\n```bash\nnpm run build\n```\n"
              }
            ],
            [
              {
                "kind": "text",
                "text": "Build the exported docs site.\n\n```bash\nnpm run docs:build\n```\n"
              }
            ],
            [
              {
                "kind": "text",
                "text": "Check documentation links and anchors.\n\n```bash\nDOCS_CHECK_ANCHORS=1 npm run docs:check-links\n```"
              }
            ]
          ],
          "mathEnabled": true
        }
      }
    },
